# Auth
# Secret used to sign JWT session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Database (Turso / libSQL)
# Connection URL for your Turso database (e.g. libsql://<db>.<org>.turso.io)
TURSO_DATABASE_URL=
# Auth token for the Turso database
TURSO_AUTH_TOKEN=

# Upstash Redis
# Used for durable SSE stream state and entity locking
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# QStash (Upstash)
# Used to enqueue background AI generation jobs
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Durable SSE stream TTL in seconds (default: 86400 = 24 hours)
DURABLE_STREAM_TTL_SECONDS=86400

# Mem0 (optional)
# Enables memory-aware AI responses via @mem0/vercel-ai-provider
MEM0_API_KEY=
# Model used by Mem0 for memory extraction (optional, defaults to provider default)
MEM0_MODEL=

# Exa (optional)
# Used for AI-powered content search/curation
EXA_API_KEY=
