default_platform(:ios)

XCODEPROJ = "betterwriter/betterwriter.xcodeproj"
SCHEME = "betterwriter"
# swift-format config lives at repo root, two dirs up from apps/ios/
SWIFT_FORMAT_CONFIG = "../../.swift-format"

platform :ios do

  # ── PR checks ──────────────────────────────────────────────

  desc "Lint Swift files with swift-format"
  lane :lint do
    sh(
      "swift-format", "lint",
      "--strict",
      "--configuration", SWIFT_FORMAT_CONFIG,
      "--recursive",
      "betterwriter/betterwriter/"
    )
    UI.success("swift-format lint passed!")
  end

  desc "Build for simulator (no signing)"
  lane :build do
    xcodebuild(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator",
      xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO",
      build: true,
      clean: true
    )
  end

  # ── TestFlight deployment ──────────────────────────────────

  desc "Deploy to TestFlight"
  lane :beta do
    # 1. Set up App Store Connect API key from env
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200
    )

    # 2. Create a temporary keychain for CI
    setup_ci

    # 3. Sync signing certificates & profiles
    match(
      type: "appstore",
      readonly: true,
      api_key: api_key
    )

    # 4. Increment build number (use CI run number)
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || "1",
      xcodeproj: XCODEPROJ
    )

    # 5. Build the IPA
    gym(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "betterwriter.ipa",
      clean: true
    )

    # 6. Upload to TestFlight
    pilot(
      api_key: api_key,
      ipa: "./build/betterwriter.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
